PORT=5000
FRONTEND_URL=https://spherewalk.luckyverse.tech

# ⚠️  Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_ME_WITH_64_CHAR_RANDOM_HEX

# Grok API key from https://console.x.ai/
GROK_API_KEY=YOUR_GROK_API_KEY_HERE

# SQLite DB path (relative to backend root)
DATABASE_URL=file:./campus.db
